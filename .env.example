# PostgreSQL connection used by the API and Drizzle.
DATABASE_URL=postgresql://eprocurement:replace-me@localhost:5432/eprocurement

# Generate with: openssl rand -hex 32
SESSION_SECRET=replace-with-a-random-value-of-at-least-32-characters

PORT=5000

# Optional: set all three only to provision the first administrator.
# Remove BOOTSTRAP_ADMIN_PASSWORD after the account is created.
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
